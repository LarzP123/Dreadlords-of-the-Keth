<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="TestGame" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/TestGame" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-std=c99" />
					<Add option="-g" />
					<Add option="-DDEBUG" />
				</Compiler>
				<Linker>
					<Add option="-lfreeglut -lglew32 -lopengl32 -lglu32" />
					<LinkerExe value="CCompiler" />
				</Linker>
				<ExtraCommands>
					<Add after='xcopy /y &quot;$(PROJECT_DIR)\bin\debug\*.exe&quot; &quot;$(PROJECT_DIR)\&quot;' />
				</ExtraCommands>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/TestGame" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-std=c99" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add option="-lfreeglut -lglew32 -lopengl32 -lglu32" />
					<LinkerExe value="CCompiler" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
