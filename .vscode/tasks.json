{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:\\msys64\\mingw64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}\\main.c",
                "${workspaceFolder}\\code\\*.c",
                "${workspaceFolder}\\code\\*.h",
                "-I",
                "${workspaceFolder}\\.vscode\\dependencies\\include",
                "-L",
                "${workspaceFolder}\\.vscode\\dependencies\\bin\\x64",
                "-L",
                "${workspaceFolder}\\.vscode\\dependencies\\lib\\x64",
                "-o",
                "${workspaceFolder}\\TestGame.exe",
                "-lfreeglut",
                "-lglew32",
                "-lopengl32",
                "-lglu32"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}